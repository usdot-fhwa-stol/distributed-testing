# BUILD COMMAND: VERSION=P-1.1.0 && sudo DOCKER_BUILDKIT=1 docker build --secret id=usdotfhwastol_token,src=usdotfhwastol_token --build-arg VERSION=$VERSION -t usdotfhwaops/v2xhubamd:voices-$VERSION . --progress=plain -f base_v2xhub_Dockerfile_P_1-1-0
