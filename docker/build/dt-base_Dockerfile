#
# BUILD COMMAND: VERSION=0.0.1 && source build-assets.env && sudo DOCKER_BUILDKIT=1 docker build --build-arg VERSION=$VERSION --build-context assets="$BUILD_DIR" -t usdotfhwastoldev/dt-base:$VERSION . --progress=plain -f dt-base_Dockerfile
#

FROM ubuntu:22.04 AS build

SHELL ["/bin/bash", "-ec"]

RUN useradd -ms /bin/bash dt_user
WORKDIR /home/dt_user

USER root

RUN apt update && \
    apt install -y zstd
     

USER dt_user

# INSTALL TENA deb
RUN --mount=type=bind,from=assets,source=.,target=/mnt/build,readonly \
    set -euo pipefail; \
    dpkg -x --force-overwrite /mnt/build/TENA-MiddlewareSDK-v6.0.9.A@Product@u2204-gcc11-64-*.deb . && \
    ar -x /mnt/build/TENA-MiddlewareSDK-v6.0.9.A@Product@u2204-gcc11-64-*.deb && \
    tar xf control.tar.* && \
    # move the postinst script into TENA dir to make it easier to copy and run later on final container
    mv ./postinst ./opt/TENA/postinst-MW 

# Install DT OMs
RUN --mount=type=bind,from=assets,source=.,target=/mnt/build,readonly \
    set -euo pipefail; \
    dpkg -x --force-overwrite /mnt/build/VUG-Combined-Distribution-v1.2.2@Product@u2204-gcc11-64-*.deb . && \
    ar -x /mnt/build/VUG-Combined-Distribution-v1.2.2@Product@u2204-gcc11-64-*.deb && \
    tar xf control.tar.* && \
    # move the postinst script into TENA dir to make it easier to copy and run later on final container
    mv ./postinst ./opt/TENA/postinst-DIST

FROM ubuntu:22.04

RUN useradd -ms /bin/bash dt_user
USER dt_user
ARG USER="dt_user"

WORKDIR /home/dt_user

COPY --from=build /home/dt_user/opt/TENA /home/dt_user/TENA
RUN DSTROOT=/home/dt_user ./TENA/postinst-MW
RUN DSTROOT=/home/dt_user ./TENA/postinst-DIST

ARG VERSION=dev
LABEL version=${VERSION}
LABEL description="Base Distributed Testing Docker image with base tena installation"

SHELL ["/bin/bash", "-ec"]

ARG DEBIAN_FRONTEND="noninteractive"
ARG TZ="America/New_York"

RUN echo 'source /home/dt_user/TENA/6.0.9/scripts/tenaenv-u2204-gcc11-64-v6.0.9.sh' >> /home/dt_user/.bashrc

