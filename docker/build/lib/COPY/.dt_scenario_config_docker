# SPECIAL DOCKER VUG_CONFIG TO OVERWRITE DOCKER DIRECTORIES

# source $HOME/.dt_scenario_config_link

# if we have a VUG_VPN_EM_ADDRESS, we must be using the VPN,
#   - overwrite the VUG_EM_ADDRESS with the new VUG_VPN_EM_ADDRESS
if [[ ! -z $VUG_VPN_EM_ADDRESS ]]; then
    export VUG_EM_ADDRESS=$VUG_VPN_EM_ADDRESS
fi

# ADAPTER VERSION CONFIG
export VUG_CARLA_ADAPTER_VERSION="CARLAtenaAdapter-2.1.0"
export VUG_DEBUG_CARLA_ADAPTER_VERSION="debug-CARLAtenaAdapter-1.5.0"
export VUG_SCENARIO_PUBLISHER_VERSION="scenario-publisher-2.0.1"
export VUG_ENTITY_GENERATOR_VERSION="tena-entity-generator-2.0.0"
export VUG_TRAFFIC_LIGHT_ENTITY_GENERATOR_VERSION="TENATrafficLightEntityGenerator-0.0.5"
export VUG_V2X_ADAPTER_VERSION="TENAV2XMessageAdapter-2.0.0"
export VUG_JSON_STREAMER_VERSION="JSONstreamer-v1.0.2"
export VUG_JSON_PUBLISHER_VERSION="JSONpublisher-v1.0.2"

# TENA APPLICATION VERSIONS
export VUG_TDCS_PATH=$VUG_LOCAL_TDCS_INSTALL_PATH/Combined-v1.2.2-DataCollection-v1.1.17
export VUG_PLAYBACK_TOOL_PATH=$VUG_LOCAL_TDCS_INSTALL_PATH/Combined-v1.2.2-PlaybackTool-v1.1.17
export VUG_EM_PATH=$VUG_LOCAL_TENA_PATH/executionManager-v6.0.9
export VUG_TENA_SOURCE_SCRIPT_FILE=$VUG_LOCAL_TENA_PATH/6.0.9/scripts/tenaenv-u2204-gcc11-64-v6.0.9.sh
export VUG_JSON_STREAMER_PATH=$VUG_LOCAL_JSON_TOOLS_INSTALL_PATH/Combined-v1.2.2-JSONstreamer-v1.0.2
export VUG_JSON_PUBLISHER_PATH=$VUG_LOCAL_JSON_TOOLS_INSTALL_PATH/Combined-v1.2.2-JSONpublisher-v1.0.2

if [ $VUG_CONTAINER_IMAGE == "dt-core" ]; then
    source $VUG_TENA_SOURCE_SCRIPT_FILE
fi

# CARLA PYTHON API LOCATION
export VUG_CARLA_EGG_DIR=$VUG_LOCAL_CARLA_PATH/PythonAPI/carla/dist/