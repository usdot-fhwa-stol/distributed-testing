#
# BUILD COMMAND: VERSION=0.0.1 && sudo DOCKER_BUILDKIT=1 docker build --build-arg version=$VERSION -t usdotfhwastoldev/voices:P-$VERSION . --progress=plain -f P_Dockerfile
#

FROM usdotfhwastoldev/voices:base-P-latest AS build

SHELL ["/bin/bash", "-ec"]

ARG DEBIAN_FRONTEND="noninteractive"
ARG TZ="America/New_York"

USER dt_user
ENV USER="dt_user"

WORKDIR /home/$USER

USER root

RUN apt update && \
    apt install -y python3-pip rsync zstd unzip

RUN pip3 install gdown

USER dt_user

RUN mkdir /home/$USER/INSTALL && mkdir /home/$USER/INSTALL/TDCS && mkdir /home/$USER/INSTALL/DV

# VUG-P???-Combined-DataCollectionDistribution-v1.1.0@Product@u2204-gcc11-64-vbe110466.deb
WORKDIR /home/$USER/INSTALL/TDCS
RUN gdown 1xuLT9aZ4GFpiVsrtc3RUBUO-ziDxv_yZ

# TDCS-DataView-v1.5.4@Product@u2204-gcc11-64-vall
WORKDIR /home/$USER/INSTALL/DV
RUN gdown 1UojRtJBZHgS9U17hwq653sH2VjqRbOzq

# INSTALL TENA DataView
WORKDIR /home/$USER/INSTALL/DV
RUN dpkg -x --force-overwrite ./TDCS-DataView-v1.5.4@Product@u2204-gcc11-64-*.deb .
RUN ar -x ./TDCS-DataView-v1.5.4@Product@u2204-gcc11-64-*.deb
RUN tar xf control.tar.*
# move the postinst script into TENA dir to make it easier to copy and run later on final container
RUN mv ./postinst ./opt/TENA/postinst-DV

# INSTALL TENA Data Collection System
WORKDIR /home/$USER/INSTALL/TDCS
RUN dpkg -x --force-overwrite ./VUG-P???-Combined-DataCollectionDistribution-*.deb .
RUN ar -x ./VUG-P???-Combined-DataCollectionDistribution-*.deb
RUN tar xf control.tar.*
# move the postinst script into TENA dir to make it easier to copy and run later on final container
RUN mv ./postinst ./opt/TENA/postinst-TDCS

WORKDIR /home/$USER

USER root
RUN rsync -a /home/$USER/INSTALL/TDCS/opt/TENA/ /home/$USER/INSTALL/DV/opt/TENA/ /home/$USER/TENA
RUN chown -R $USER:$USER /home/$USER/TENA
USER $USER
ENV USER="dt_user"

# RUN gdown 1yFN-G2PaNna3kHtXop3XqVFu632l62HB
# CARLA_0.9.15 (contains just the PythonAPI folder for CARLA PythonAPI capabilities)
RUN gdown 1mSt0_8wZGn6q8ist3ZAyhkVLT_W9fMR_
RUN unzip CARLA_0.9.15.zip

FROM usdotfhwastoldev/voices:base-P-latest

ARG VERSION=dev
LABEL version=${VERSION}
LABEL description="Docker image for interoperability test"

ARG DEBIAN_FRONTEND="noninteractive" 
ARG TZ="America/New_York"

USER dt_user
ENV USER="dt_user"

WORKDIR /home/$USER

USER root

RUN apt update && apt install -y software-properties-common


# INSTALL apt packages 
RUN apt clean && \
    apt-get update && \
    # add sumo repo 
    apt install -y software-properties-common && \
    add-apt-repository ppa:sumo/stable && apt-get update && \
    apt install -y \
    # install apt utils for installing packages (mostly for TENA console)
    apt-utils \
    # install boost
    # libboost-all-dev \
    # install qt packages
    libxcb-xinerama0 libfreetype6 libfontconfig libsm6 libxi6 libx11-xcb-dev libxcb-icccm4 libxcb-image0 libxcb-keysyms1 libxcb-randr0 libxcb-render-util0 libxcb-shape0 libxcb-sync1 libxcb-xfixes0 libxcb-xkb1 libxkbcommon-x11-0 libjpeg8 libtiff5 \
    # install debug tools
    iputils-ping nano tshark git tcpdump nethogs rsync \
    # install sumo tools
    sumo sumo-tools sumo-doc \
    # install iproute2
    iproute2 \
    # install dumb init to enable gracefully stopping container processes
    dumb-init && \
    # cleanup apt lists
    rm -rf /var/lib/apt/lists/*

# Install Python 3.10 and clean NumPy
RUN apt-get clean && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get purge -y python3-numpy && \
    rm -rf /usr/lib/python3*/dist-packages/numpy* && \
    apt-get install -y \
        python3.10 \
        python3.10-dev \
        python3.10-distutils \
        curl && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 100 && \
    update-alternatives --set python3 /usr/bin/python3.10 && \
    curl -sS https://bootstrap.pypa.io/get-pip.py | python3.10 && \
    python3 -m pip install --upgrade pip

# Switch to non-root user
USER dt_user
ENV PATH="/home/dt_user/.local/bin:$PATH"

# Install Python packages as dt_user
RUN python3 -m pip install --no-cache-dir --user --force-reinstall numpy && \
    python3 -m pip install --no-cache-dir --user carla==0.9.15 pygame pycrate traci lxml networkx pynput matplotlib && \
    python3 -m pip install --no-cache-dir --user pandas && \
    rm -rf /home/dt_user/.cache

USER root

# ------------------------------------------------------------------------
# Build and install Boost 1.82.0
# ------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential g++ cmake wget curl python3-dev \
    && cd /tmp \
    && BOOST_VERSION=1.82.0 \
    && BOOST_PACKAGE=boost_${BOOST_VERSION//./_} \
    && wget https://archives.boost.io/release/${BOOST_VERSION}/source/${BOOST_PACKAGE}.tar.gz \
    && tar -xzf ${BOOST_PACKAGE}.tar.gz \
    && cd ${BOOST_PACKAGE} \
    && ./bootstrap.sh --prefix=/opt/boost-1.82.0 \
         --with-libraries=filesystem,system,thread,regex,program_options \
    && ./b2 -j"$(nproc)" install \
    && cd /tmp \
    && rm -rf ${BOOST_PACKAGE} ${BOOST_PACKAGE}.tar.gz

# ------------------------------------------------------------------------
# Environment setup for Boost 1.82.0
# ------------------------------------------------------------------------
ENV BOOST_ROOT=/opt/boost-1.82.0 \
    CMAKE_PREFIX_PATH=/opt/boost-1.82.0:$CMAKE_PREFIX_PATH \
    LD_LIBRARY_PATH=/opt/boost-1.82.0/lib:$LD_LIBRARY_PATH

RUN rm -rf /home/$USER/TENA
USER $USER

COPY --chown=dt_user:dt_user --from=build /home/$USER/TENA /home/$USER/TENA

RUN DSTROOT=/home/dt_user ./TENA/postinst-DV
RUN DSTROOT=/home/dt_user ./TENA/postinst-TDCS

COPY --chown=dt_user:dt_user --from=build /home/$USER/CARLA_0.9.15 /home/$USER/CARLA_0.9.15

COPY --chown=dt_user:dt_user ./lib/COPY /home/$USER

# Make Start Scripts executable

USER root
RUN chmod a+x -R /home/$USER/start_scripts/
USER dt_user

# CLEANUP

RUN echo 'source /home/$USER/start_scripts/setup-docker.sh' >> /home/$USER/.bashrc


CMD ["/usr/bin/dumb-init","-v","--","/bin/bash","-l","-c","/home/$USER/start_scripts/startup-apps.sh"]
