#
# BUILD COMMAND: VERSION=0.0.1 && source build-assets.env && DOCKER_BUILDKIT=1 docker build --build-arg version=$VERSION --build-context assets="$BUILD_DIR" -t harbor.distributedtesting.org/distributed-testing/dt-core:$VERSION . --progress=plain -f dt-core_Dockerfile
#

# ----------------------- BUILD STAGE ----------------------- #
FROM harbor.distributedtesting.org/distributed-testing/dt-base:latest AS build

SHELL ["/bin/bash", "-ec"]

ARG DEBIAN_FRONTEND="noninteractive"
ARG TZ="America/New_York"

USER dt_user
ENV USER="dt_user"

WORKDIR /home/$USER

USER root

RUN apt update && \
    apt install -y python3-pip rsync zstd unzip

USER dt_user

RUN mkdir /home/$USER/INSTALL && mkdir /home/$USER/INSTALL/TDCS && mkdir /home/$USER/INSTALL/DV && mkdir /home/$USER/INSTALL/JSON

ARG DV_VERSION="v1.5.4"
# INSTALL TENA DataView
WORKDIR /home/$USER/INSTALL/DV
RUN --mount=type=bind,from=assets,source=.,target=/mnt/build,readonly \
    set -euo pipefail; \
    dpkg -x --force-overwrite /mnt/build/TDCS-DataView-${DV_VERSION}@Product@u2204-gcc11-64*.deb . && \
    ar -x /mnt/build/TDCS-DataView-${DV_VERSION}@Product@u2204-gcc11-64*.deb && \
    tar xf control.tar.* && \
    # move the postinst script into TENA dir to make it easier to copy and run later on final container
    mv ./postinst ./opt/TENA/postinst-DV

# INSTALL TENA Data Collection System
ARG TDCS_VERSION="VUG-Combined-DataCollectionDistribution-v1.2.3"
WORKDIR /home/$USER/INSTALL/TDCS
RUN --mount=type=bind,from=assets,source=.,target=/mnt/build,readonly \
    set -euo pipefail; \
    dpkg -x --force-overwrite /mnt/build/${TDCS_VERSION}@Product@u2204-gcc11-64*.deb . && \
    ar -x /mnt/build/${TDCS_VERSION}@Product@u2204-gcc11-64*.deb && \
    tar xf control.tar.* && \
    # move the postinst script into TENA dir to make it easier to copy and run later on final container
    mv ./postinst ./opt/TENA/postinst-TDCS

# INSTALL TENA JSON Tools
ARG JSON_VERSION="VUG-Combined-JSONtoolsDistribution-v1.2.3"
WORKDIR /home/$USER/INSTALL/JSON
RUN --mount=type=bind,from=assets,source=.,target=/mnt/build,readonly \
    export ; \    
    set -euo pipefail; \
    dpkg -x --force-overwrite /mnt/build/${JSON_VERSION}@Product@u2204-gcc11-64*.deb . && \
    ar -x /mnt/build/${JSON_VERSION}@Product@u2204-gcc11-64*.deb && \
    tar xf control.tar.* && \
    # move the postinst script into TENA dir to make it easier to copy and run later on final container
    mv ./postinst ./opt/TENA/postinst-JSON

WORKDIR /home/$USER

USER root
RUN rsync -a /home/$USER/INSTALL/TDCS/opt/TENA/ /home/$USER/INSTALL/DV/opt/TENA/ /home/$USER/INSTALL/JSON/opt/TENA/ /home/$USER/TENA

RUN chown -R root:root /home/$USER/TENA

RUN DSTROOT=/home/dt_user bash /home/$USER/TENA/postinst-DV || true && \
    DSTROOT=/home/dt_user bash /home/$USER/TENA/postinst-TDCS || true && \
    sed -i '/^chown -R root/d;/^chgrp -R root/d' /home/$USER/TENA/postinst-JSON && \
    DSTROOT=/home/dt_user bash /home/$USER/TENA/postinst-JSON || true

RUN find /home/$USER/TENA -type d -exec chmod 755 {} + && \
    find /home/$USER/TENA -type f -exec chmod a+r {} + && \
    find /home/$USER/TENA -type f -name "*.sh" -exec chmod a+x {} + && \
    find /home/$USER/TENA -type f -perm /111 -exec chmod a+x {} + && \
    chown -R dt_user:dt_user /home/$USER/TENA

USER dt_user

# CARLA_0.9.15 (contains just the PythonAPI folder for CARLA PythonAPI capabilities)
RUN --mount=type=bind,from=assets,source=.,target=/mnt/build,readonly \
    unzip /mnt/build/CARLA_0.9.15.zip && \
    mv CARLA_0.9.15 $HOME/CARLA

# ----------------------- RUNTIME STAGE ----------------------- #
FROM harbor.distributedtesting.org/distributed-testing/dt-base:latest

ARG VERSION=dev
LABEL version=${VERSION}
LABEL description="Docker image for interoperability test"

ARG DEBIAN_FRONTEND="noninteractive" 
ARG TZ="America/New_York"

USER dt_user
ENV USER="dt_user"

WORKDIR /home/$USER

USER root

RUN apt update && apt install -y software-properties-common


# INSTALL apt packages 
RUN apt clean && \
    apt-get update && \
    # add sumo repo 
    apt install -y software-properties-common && \
    add-apt-repository ppa:sumo/stable && apt-get update && \
    apt install -y \
    # install apt utils for installing packages (mostly for TENA console)
    apt-utils \
    # install qt packages
    libxcb-xinerama0 libfreetype6 libfontconfig libsm6 libxi6 libx11-xcb1 libxcb-cursor0 libxcb-icccm4 libxcb-image0 libxcb-keysyms1 libxcb-randr0 libxcb-render-util0 libxcb-shape0 libxcb-sync1 libxcb-xfixes0 libxcb-xkb1 libxkbcommon-x11-0 libjpeg8 libtiff5 \
    # install debug tools
    iputils-ping nano tshark git tcpdump nethogs rsync \
    # install sumo tools
    sumo sumo-tools sumo-doc \
    # install iproute2
    iproute2 \
    # install dumb init to enable gracefully stopping container processes
    dumb-init \
    # install locales and set to UTF-8 for JSON Streamer 
    locales && \
    locale-gen en_US.UTF-8 && \
    update-locale LANG=en_US.UTF-8 && \
    # cleanup apt lists
    rm -rf /var/lib/apt/lists/*

# Set ENV for locales to UTF-8
ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

# Install Python 3.7 and clean NumPy
RUN apt-get clean && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get purge -y python3-numpy && \
    rm -rf /usr/lib/python3*/dist-packages/numpy* && \
    apt-get install -y \
        python3.7 \
        python3.7-dev \
        python3.7-distutils \
        libevdev-dev gcc g++\
        curl && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.7 100 && \
    update-alternatives --set python3 /usr/bin/python3.7 && \
    curl -sS https://bootstrap.pypa.io/pip/3.7/get-pip.py | python3.7 && \
    python3.7 -m pip install --upgrade "pip<23.1" "setuptools<68" "wheel<0.41"

# Switch to non-root user
USER dt_user
ENV PATH="/home/dt_user/.local/bin:$PATH"

# Install Python packages as dt_user
RUN python3 -m pip install --no-cache-dir --user --force-reinstall "numpy<=1.21.6" && \
    python3 -m pip install --no-cache-dir --user \
        "pygame==2.1.3" \
        pycrate \
        traci \
        pynput \
        requests \
        scapy \
        shapely \
        "lxml==4.9.4" \
        "networkx==2.6.3" \
        "matplotlib<=3.5.3" && \
    python3 -m pip install --no-cache-dir --user "pandas==1.3.5" && \
    rm -rf /home/dt_user/.cache

USER root
RUN rm -rf /home/$USER/TENA

COPY --chown=dt_user:dt_user --from=build /home/$USER/TENA /home/$USER/TENA

COPY --chown=dt_user:dt_user --from=build /home/$USER/CARLA /home/$USER/CARLA

COPY --chown=dt_user:dt_user ./lib/COPY /home/$USER

# Make Start Scripts executable

USER root
RUN chmod a+x -R /home/$USER/start_scripts/
USER dt_user

# CLEANUP

RUN echo 'source /home/$USER/start_scripts/setup-docker.sh' >> /home/$USER/.bashrc


CMD ["/usr/bin/dumb-init","-v","--","/bin/bash","-l","-c","/home/$USER/start_scripts/startup-apps.sh"]
