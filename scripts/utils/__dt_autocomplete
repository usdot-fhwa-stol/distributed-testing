__dt()
{
  local cur prev subcmds config_subcmds
  COMPREPLY=()
  _get_comp_words_by_ref -n : cur prev
  subcmds="init config start stop ps help exec download connect disconnect"
  config_subcmds=" print status create"

  case ${prev} in
    "config")
      COMPREPLY=( $(compgen -W "${config_subcmds}" -- ${cur}) )
      ;;
    "dt")
      COMPREPLY=( $(compgen -W "${subcmds}" -- ${cur}) )
      ;;
    "connect")
      COMPREPLY=( $(compgen -f -- ${cur}) )
      ;;
    *)
      return
      ;;
  esac
}

complete -F __dt dt

