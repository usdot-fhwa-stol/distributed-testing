dt__connect() {
    # Usage: dt connect <path-to-openvpn-config>
    if [[ -z "$1" ]]; then
        echo "Usage: dt connect <path-to-openvpn-config>"
        return 1
    fi

    # Expand ~ if present and keep quotes for spaces
    local cfg="${1/#\~/$HOME}"

    # Basic checks
    if ! command -v openvpn3 >/dev/null 2>&1; then
        echo "Error: openvpn3 not found on PATH. Please install openvpn3."
        return 1
    fi

    if [[ ! -f "$cfg" ]]; then
        echo "Error: config file not found: $cfg"
        return 1
    fi

    echo "Starting OpenVPN session with config: $cfg"
    sudo openvpn3 session-start --config "$cfg"
}

dt__disconnect() {

    # Basic checks
    if ! command -v openvpn3 >/dev/null 2>&1; then
        echo "Error: openvpn3 not found on PATH. Please install openvpn3."
        return 1
    fi

    echo "Disconnecting from VPN"

    "$VUG_LOCAL_DT_PATH/scripts/utils/stop_current_vpn_connection.sh"
}

dt-config__set() {
    local args=()

    # Parse optional args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --site)
                if [[ -n "$2" && "$2" != --* ]]; then
                    args+=(--site "$2")
                    shift 2
                else
                    echo "Error: --site requires a filename argument."
                    return 1
                fi
                ;;
            --scenario)
                if [[ -n "$2" && "$2" != --* ]]; then
                    args+=(--scenario "$2")
                    shift 2
                else
                    echo "Error: --scenario requires a filename argument."
                    return 1
                fi
                ;;
            *)
                echo "Unknown option: $1"
                echo "Usage: dt config set [--site <site.config>] [--scenario <scenario.config>]"
                return 1
                ;;
        esac
    done

    "$VUG_LOCAL_DT_PATH/config/set_dt_config.sh" "${args[@]}"
}

dt-config__create() {
    if [[ -z "$1" || ( "$1" != "site" && "$1" != "scenario" ) ]]; then
        echo "Usage: dt config create [site|scenario]"
        return 1
    fi

    local type="$1"
    local config_dir="$VUG_LOCAL_DT_PATH/config/${type}_config"
    local default_config="$config_dir/default_${type}.config"

    if [[ ! -f "$default_config" ]]; then
        echo "Error: Default config not found at $default_config"
        return 1
    fi

    local example_name="fhwa.config"
    [[ "$type" == "scenario" ]] && example_name="test_5.config"

    echo "Creating new $type configuration file."
    while true; do
        read -p "Enter a name for the new config file (e.g., $example_name): " config_name
        if [[ "$config_name" =~ \.config$ ]]; then
            break
        else
            echo "Invalid filename. It must end in .config"
        fi
    done

    local new_config_path="$config_dir/$config_name"
    if [[ -f "$new_config_path" ]]; then
        read -p "File already exists. Overwrite? (y/N): " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            echo "Aborting."
            return 1
        fi
    fi

    # Copy default template
    cp "$default_config" "$new_config_path"

    # === SITE CONFIG PROMPTS ===
    if [[ "$type" == "site" ]]; then
        local VUG_LOCAL_ADDRESS=""
        while true; do
            read -p "Enter VUG_LOCAL_ADDRESS (IPv4): " VUG_LOCAL_ADDRESS
            if [[ "$VUG_LOCAL_ADDRESS" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
                break
            else
                echo "Invalid IP address. Try again."
            fi
        done

        local VUG_SHORT_IDENTIFIER=""
        while true; do
            read -p "Enter VUG_SHORT_IDENTIFIER (uppercase, < 8 characters): " VUG_SHORT_IDENTIFIER
            if [[ "$VUG_SHORT_IDENTIFIER" =~ ^[A-Z0-9]{1,8}$ ]]; then
                break
            else
                echo "Invalid identifier. Use all caps and up to 8 characters."
            fi
        done

        local VUG_DOCKER_START_CARLA=""
        while true; do
            read -p "Would you be using CARLA? (true/false): " VUG_DOCKER_START_CARLA
            if [[ "$VUG_DOCKER_START_CARLA" =~ ^(true|false)$ ]]; then
                break
            else
                echo "Invalid input. Use 'true' or 'false'."
            fi
        done
        
        # replace /home/<username> with $HOME to keep the config tidy
        sed -i "s|^export VUG_LOCAL_DT_PATH=.*|export VUG_LOCAL_DT_PATH=${VUG_LOCAL_DT_PATH/#$HOME/\$HOME}|" "$new_config_path"
        sed -i "s|^export VUG_LOCAL_ADDRESS=.*|export VUG_LOCAL_ADDRESS='$VUG_LOCAL_ADDRESS'|" "$new_config_path"
        sed -i "s|^export VUG_SHORT_IDENTIFIER=.*|export VUG_SHORT_IDENTIFIER='$VUG_SHORT_IDENTIFIER'|" "$new_config_path"
        sed -i "s|^export VUG_DOCKER_START_CARLA=.*|export VUG_DOCKER_START_CARLA=$VUG_DOCKER_START_CARLA|" "$new_config_path"

    # === SCENARIO CONFIG PROMPTS ===
    elif [[ "$type" == "scenario" ]]; then
        local VUG_EM_ADDRESS=""
        while true; do
            read -p "Enter VUG_EM_ADDRESS (IPv4): " VUG_EM_ADDRESS
            if [[ "$VUG_EM_ADDRESS" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
                break
            else
                echo "Invalid IP address. Try again."
            fi
        done

        read -p "Enter VUG_CARLA_MAP_NAME (map name): " VUG_CARLA_MAP_NAME
        read -p "Enter VUG_INTERSECTION_ID (optional, leave blank if none): " VUG_INTERSECTION_ID

        local VUG_SCENARIO_FILE=""
        while true; do
            read -p "Enter VUG_SCENARIO_FILE (must end in .xml): " VUG_SCENARIO_FILE
            if [[ "$VUG_SCENARIO_FILE" =~ \.xml$ ]]; then
                break
            else
                echo "Invalid scenario file. Must end in .xml"
            fi
        done

        sed -i "s|^export VUG_EM_ADDRESS=.*|export VUG_EM_ADDRESS='$VUG_EM_ADDRESS'|" "$new_config_path"
        sed -i "s|^export VUG_CARLA_MAP_NAME=.*|export VUG_CARLA_MAP_NAME='$VUG_CARLA_MAP_NAME'|" "$new_config_path"
        sed -i "s|^export VUG_INTERSECTION_ID=.*|export VUG_INTERSECTION_ID='$VUG_INTERSECTION_ID'|" "$new_config_path"
        sed -i "s|^export VUG_SCENARIO_FILE=.*|export VUG_SCENARIO_FILE='$VUG_SCENARIO_FILE'|" "$new_config_path"
    fi

    echo "New $type config created at: $new_config_path"
}

dt-config__print() {
    local dt_site_config="$HOME/.dt_site_config"
    local dt_scenario_config="$HOME/.dt_scenario_config"

    echo "Distributed Testing Site Config ($dt_site_config):"
    if [[ -f "$dt_site_config" ]]; then
        cat "$dt_site_config"
    else
        echo "(Not found)"
    fi

    echo ""
    echo "Distributed Testing Scenario Config ($dt_scenario_config):"
    if [[ -f "$dt_scenario_config" ]]; then
        cat "$dt_scenario_config"
    else
        echo "(Not found)"
    fi
}

dt__init() {
    if [[ -z "$1" ]]; then
        echo "Install path not set..."
        return 1
    fi

    export VUG_LOCAL_DT_PATH="$1"

    echo ""
    read -p "Would you like to create a new site config? [Y/n] " confirm
    if [[ ! "$confirm" =~ ^[Nn]$ ]]; then
        dt-config__create site
    fi

    echo ""
    read -p "Would you like to create a new scenario config? [Y/n] " confirm
    if [[ ! "$confirm" =~ ^[Nn]$ ]]; then
        dt-config__create scenario
    fi

    echo ""
    read -p "Would you like to set your config? [Y/n] " confirm
    if [[ ! "$confirm" =~ ^[Nn]$ ]]; then
        dt-config__set
    fi

}

dt__download() {
    # Capture all extra arguments
    EXTRA_ARGS=("$@")
    
    # Check that the env variable is set and compose file exists
    if [[ -z "$VUG_LOCAL_DT_PATH" ]]; then
        echo "Error: VUG_LOCAL_DT_PATH is not set."
        return 1
    fi

    COMPOSE_FILE="$VUG_LOCAL_DT_PATH/docker/docker-compose.yml"

    if [[ ! -f "$COMPOSE_FILE" ]]; then
        echo "Error: Cannot find docker-compose.yml at $COMPOSE_FILE"
        return 1
    fi

    echo "Stopping DT Containers:"
    echo ""
    # run the docker compose pull, pass any extra args
    # using script to simulate a TTY to get the proper formatting
    # grep -v out the warning lines for env vars not set, we dont care on shutdown
    script -q -c "docker compose -f \"$COMPOSE_FILE\" pull ${EXTRA_ARGS[@]}" /dev/null | grep -v 'variable is not set. Defaulting to a blank string'
}

