dt__exec() {
    local container="voices"
    local command="bash"
    local exec_args=()

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --container)
                container="$2"
                shift 2
                ;;
            --command)
                command="$2"
                shift 2
                ;;
            *)
                exec_args+=("$1")
                shift
                ;;
        esac
    done

    # Validate container
    if [[ "$container" != "voices" && "$container" != "carla-voices" ]]; then
        echo "Error: Unknown container '$container'"
        echo "Valid options are: voices or carla-voices"
        return 1
    fi

    # Set default exec args if none provided
    if [[ ${#exec_args[@]} -eq 0 ]]; then
        exec_args=(-it)
    fi

    echo "Attaching to container '$container' with args: ${exec_args[*]} and command: $command"
    docker exec "${exec_args[@]}" "$container" $command
}

