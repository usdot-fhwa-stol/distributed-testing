  <intersectionSignalControllers>
    <intersectionSignalController name="Town04_Main" adapterName="V2XEG-1" lvcIndicator="Live">
      <userData>
        <CARLA>
          <controllers>
          <!--     this is spat linking, we only use ID as name isnt required  -->
          <!--   in future, maybe we try to check for both, but just ID for now-->
            <controller name="" id="0"/>
          </controllers>      
        </CARLA>
      </userData>
    </intersectionSignalController>
  </intersectionSignalControllers>
  <phaseSignalMappings>
    <!-- name of config doesnt matter, match controllerName with intersectionSignalController name  -->

    <configuration name="Town04_Main Configuration" controllerName="Town04_Main">
      <controller name="" id="">
        <control signalId="1629" type=""> <!-- SB, Actor 135 -->
          <userData><phase>4</phase></userData>
