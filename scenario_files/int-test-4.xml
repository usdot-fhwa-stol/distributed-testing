  <intersectionSignalControllers>
  <!--                           this should be used as identifier -->
    <intersectionSignalController name="Town04_Main" adapterType="spat-adapter" adapterName="SPAT-1" lvcIndicator="Live">
      <userData>
        <CARLA>
          <controllers>
          <!--     this is spat linking, we only use ID as name isnt required  -->
          <!--   in future, maybe we try to check for both, but just ID for now-->
            <controller name="" id="549"/>
          </controllers>      
        </CARLA>
      </userData>
    </intersectionSignalController>
  </intersectionSignalControllers>

  <phaseSignalMappings>
  <!-- name of config doesnt matter, match controllerName with intersectionSignalController name  -->
    <controllerMapping name="Town04_Main Configuration" controllerName="Town04_Main">

        <trafficSignalPhase phase="4" >
            <trafficSignalHead signalHeadID="1629"/>
        </trafficSignalPhase>
        <!-- propogate above change to these as well -->
        <phaseSignalPair phase="2" signalId="1628"/>
        <phaseSignalPair phase="8" signalId="1627"/>
        <phaseSignalPair phase="6" signalId="1626"/>

    </controllerMapping>


  </phaseSignalMappings>

  <simulations>
